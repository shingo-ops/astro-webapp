# ===================================
# Sales Anchor 環境変数テンプレート
# ===================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
# .env は .gitignore で除外されているため、GitHubにはアップロードされません。

# --- PostgreSQL ---
POSTGRES_DB=myapp_db
POSTGRES_USER=myapp_user
POSTGRES_PASSWORD=（安全なランダム文字列を設定）
DATABASE_URL=postgresql+asyncpg://myapp_user:パスワード@postgres:5432/myapp_db

# --- Firebase / Google Identity Platform ---
# AUTH_DOMAIN は ADR-032 によりカスタムドメイン auth.salesanchor.jp に切り替え。
# 切り戻し時は sales-ops-with-claude.firebaseapp.com に戻す（旧ドメインは並行維持）。
GCP_PROJECT_ID=sales-ops-with-claude
FIREBASE_API_KEY=（Firebase APIキーを設定）
FIREBASE_AUTH_DOMAIN=auth.salesanchor.jp
GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-credentials.json

# --- Vite（frontend ビルド時に埋め込まれる値、必須） ---
# これらが未設定だと frontend コンテナが auth/invalid-api-key で画面真っ白になる
# VITE_FIREBASE_AUTH_DOMAIN: ADR-032 でカスタムドメインに切替。切り戻しは旧値
# sales-ops-with-claude.firebaseapp.com に戻すだけで可（再ビルド要）。
VITE_FIREBASE_API_KEY=（Firebase APIキーを設定、FIREBASE_API_KEY と同じ値）
VITE_FIREBASE_AUTH_DOMAIN=auth.salesanchor.jp
VITE_GCP_PROJECT_ID=sales-ops-with-claude

# --- Redis ---
REDIS_PASSWORD=（安全なランダム文字列を設定）
REDIS_URL=redis://:パスワード@redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://:パスワード@redis:6379/1
CELERY_RESULT_BACKEND=redis://:パスワード@redis:6379/2

# --- アプリケーション ---
ENVIRONMENT=development
ALLOWED_ORIGINS=https://jarvis-claude.uk,https://app.salesanchor.jp,https://salesanchor.jp

# --- Public URL (Meta Data Deletion Callback の status URL 生成に使用) ---
PUBLIC_BASE_URL=https://salesanchor.jp

# --- SMTP (B6 Data Deletion Completion Email) ---
# 未設定なら idle（ログのみ）。Meta App Review はメール必須ではないので最小構成可。
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=support@salesanchor.jp

# --- Meta Webhook ---
META_VERIFY_TOKEN=your-secret-verify-token-here

# --- Meta Inbox (Phase 1-D) ---
# Page Access Token / 将来の秘密情報を Fernet で暗号化保存するための鍵。
# 32 bytes urlsafe base64 を以下のコマンドで生成し、GitHub Secrets で管理:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 鍵を紛失すると DB に保存された Page Access Token が永遠に復号できなくなる。
METADATA_FERNET_KEY=

# Phase 1-D Sprint 2: OAuth 接続 (Facebook Login + Page 選択) で必要。
# META_APP_SECRET は既存 (webhook の HMAC 検証で利用) のため再掲しない。
META_APP_ID=
META_OAUTH_REDIRECT_URI=https://app.salesanchor.jp/channels/oauth/callback
# Graph API バージョン（v19.0 が現状の安定版、しんごさん回答 Q3 暫定方針）
META_GRAPH_API_VERSION=v19.0
# 起動時に METADATA_FERNET_KEY 不正で fail-fast したい場合に "1"。
# 既存環境のローリング更新時は未設定（warning ログのみ）で安全に上げられる。
ENFORCE_METADATA_FERNET_KEY=
# Frontend の base URL（OAuth callback redirect で使用）。未設定時は ALLOWED_ORIGINS 先頭。
FRONTEND_BASE_URL=https://app.salesanchor.jp

# --- Google Calendar OAuth 連携 ---
# Firebase プロジェクト（sales-ops-with-claude）で作成した OAuth 2.0 クライアント（Web アプリケーション）
# Google Console: https://console.cloud.google.com/auth/clients?project=sales-ops-with-claude
GOOGLE_CALENDAR_CLIENT_ID=730863365967-icreuf1q3l7uenlf8iifh3hi0cumqa7e.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=（Google Calendar OAuth クライアントシークレット - GitHub Secrets 参照）
GOOGLE_CALENDAR_REDIRECT_URI=https://api.salesanchor.jp/api/v1/google-calendar/connect/callback

# --- Discord Gateway Worker (ADR-009) ---
# per-tenant Bot Token（テナントID別に Discord 開発者ポータルで Bot を作成し設定）
# 未設定時は idle 待機（接続せず）
DISCORD_GATEWAY_LOG_LEVEL=INFO
# tenant_004 = HIGH LIFE JPN
DISCORD_BOT_TOKEN_4=
DISCORD_TENANT_CODE_4=highlife-jpn

# --- Sprint 4 (F4): Gemini 2.5 Flash LLM フォールバック ---
# Google AI Studio で発行 (https://aistudio.google.com/apikey)。
# 未設定時は LLM フォールバック無効化 → rule_v1 のみで処理 (parse_status=parsed_rule_only)。
# 500 エラーにせず graceful degrade する設計 (spec F4 AC4.5)。
GEMINI_API_KEY=
# 任意: budget 超過時に通知する Discord webhook URL。
# 未設定なら通知 skip（ログのみ）。Sprint 4 専用、既存 webhook と分離可能。
ADMIN_NOTIFICATION_DISCORD_WEBHOOK=

# --- 監視・運用基盤（Monitoring Stack） ---
# Grafana 管理者ログイン
# ⚠️ 必ず本番用のパスワードに変更すること（デフォルト changeme のままだと不正アクセスのリスクあり）
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# Discord アラート通知 Webhook URL
# Discord > チャンネル設定 > 連携サービス > ウェブフック で発行。未設定の場合はアラート通知が無効（Grafanaは起動する）。
DISCORD_WEBHOOK_URL=

# Uptime Kuma API キー
# Uptime Kuma の Settings > API Keys で生成。Prometheus が /metrics をスクレイプするために必要。
UPTIME_KUMA_API_KEY=
