  "panels": [
    {
      "id": 9999,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "html",
        "content": "<div style=\"padding:4px 8px\"><p style=\"margin:0;font-size:20px;font-weight:600;line-height:1.3\">コンテナリソース詳細</p><p style=\"margin:2px 0 0;font-size:10px;opacity:0.75\">コンテナ別の CPU・メモリ・ネットワーク使用量を詳細に確認します。コンテナを選択してドリルダウンできます。</p></div>"
      },
      "transparent": true
    },
    {
      "id": 1,
      "title": "CPU使用率（コンテナ別）",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": {
              "mode": "none"
            }
          },
          "links": [
            {
              "title": "コンテナ: ${__series.name} のメモリ詳細",
              "url": "/grafana/d/container-detail?orgId=1&var-container=${__series.name}&from=${__from}&to=${__to}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"$container\", image!=\"\"}[5m]) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
