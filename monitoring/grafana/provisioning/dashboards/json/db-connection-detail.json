    {
      "id": 6,
      "title": "トランザクション数（コミット vs ロールバック）",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname!=\"\"}[5m])",
          "legendFormat": "コミット ({{datname}})",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname!=\"\"}[5m])",
          "legendFormat": "ロールバック ({{datname}})",
          "refId": "B"
        }
      ]
    },
