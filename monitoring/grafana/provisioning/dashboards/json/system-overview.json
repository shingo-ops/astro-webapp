    {
      "id": 1002,
      "title": "総合評価",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "expr": "clamp_min(0, 100 - 20 * ((max(100 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100) > bool 85) + (max((1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100) > bool 85) + (max((1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100) > bool 85) + (pg_up == bool 0) + (sum(rate(nginx_http_requests_total{status=~\"5..\"}[5m])) > bool 0.05)))",
          "legendFormat": "{{__name__}}",
          "refId": "A"
        }
      ],
      "links": [
        {
          "title": "システム概要の詳細へ",
          "url": "/grafana/d/jarvis-system-overview",
          "targetBlank": false,
          "tooltip": "インフラ詳細へ"
        }
      ]
    },
