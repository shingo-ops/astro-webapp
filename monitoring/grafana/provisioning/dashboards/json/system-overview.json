        "y": 0
      },
      "options": {
        "mode": "html",
        "content": "<div style=\"padding:4px 8px\"><p style=\"margin:0;font-size:20px;font-weight:600;line-height:1.3\">システム概要</p><p style=\"margin:2px 0 0;font-size:10px;opacity:0.75\">インフラの総合評価から詳細推移までを 1 画面で確認します。緑=OK、黄=注意、赤=異常。repo 変更だけでは反映されず、監視VPS が provisioning を読み込んだ時点で画面に現れます。</p></div>"
      },
      "transparent": true
    },
