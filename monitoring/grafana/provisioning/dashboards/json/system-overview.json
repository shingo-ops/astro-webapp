      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
