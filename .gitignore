# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm-cache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv

# Docker
*.log

# Environment variables
.env
.env.local
.env.*.local
*-password.txt

# Firebase / GCP credentials（絶対にGitHubに上げない）
firebase-credentials.json
*-credentials.json

# Database
postgres_data/
*.sql
!migrations/*.sql
# ADR-038: scripts/qa/seed-tenant.sql は QA Smoke Suite に必須のため tracked
!scripts/qa/*.sql

# SSL証明書
certbot/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build outputs
dist/
build/
*.egg-info/

# テストユーザーセットアップスクリプトのCSV出力（個別パスワード含む）
scripts/output/

# 原本スプレッドシートCSV（個人情報・顧客データを含むため絶対に上げない）
sheets/

# Claude Code エージェント（reviewer/evaluator等）のローカル成果物（active-work.md のみ共有SSoTとして追跡）
.claude-pipeline/*
!.claude-pipeline/active-work.md

# Claude Code: allowlist 戦略
# - `.claude/*` を一括 ignore し、チーム共有したい資産だけ `!` で取り戻す
# - 将来 Claude Code が `.claude/` 配下に追加する任意のファイル（cache/, sessions/, history.jsonl 等）も自動的に除外される
# - `.claude/worktrees/` は `isolation: "worktree"` で自動生成される作業ディレクトリ（上記の一括 ignore に含まれる）
.claude/*
!.claude/agents/
!.claude/settings.json
!.claude/agent-config.sh
CLAUDE.local.md

# Claude Code エージェント作業artefact（worktree並行作業・Evaluator実行で生成）
.playwright-mcp/
.coverage
/*.png
/*.json

# salesanchor.jp 静的サイト（独立プロジェクトのコンテンツ、VPS-local 管理）
# nginx/docker-compose の設定だけ repo 管理、コンテンツは追跡しない
www/salesanchor/*
!www/salesanchor/.gitkeep

# Playwright E2E (Phase 1-E F2-S3)
frontend/test-results/
frontend/playwright-report/
frontend/playwright/.cache/

# しんごさんローカル専用（commit 禁止）
docs/LP_BASELAYOUT_TAILWIND_SPEC.md

# ADR-035: External state snapshots — private サブディレクトリは commit 対象外
# （snapshot directory 自体は commit 対象、private/ 配下に意図せず secret を書いた場合の最後の砦）
external-state-snapshots/*/private/

*storybook.log
storybook-static

# PR所有権管理（各worktreeローカル — コミット対象外）
.pr-number

# Worktree UUID識別子（各worktreeローカル — コミット対象外）
.worktree-id
