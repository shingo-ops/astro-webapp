#!/bin/sh
# ADR-067: ダークモード色規約の強制
# このフックはコミット前に以下のチェックを実行します:
#   1. ESLint — TSXインラインスタイルへのhex色禁止
#   2. CSS hex色チェック — App.css等のhex色禁止
#   3. ダークモード変数パリティチェック — :root と :root.force-dark の変数一致

cd "$(git rev-parse --show-toplevel)/frontend"

echo "🔍 ADR-067: ダークモード色規約チェック中..."

# lint-staged で変更ファイルのみチェック
npx lint-staged

# index.css が変更された場合はパリティチェック
if git diff --cached --name-only | grep -q "frontend/src/index.css"; then
  echo "📋 index.css 変更検出 → ダークモード変数パリティチェック実行"
  node scripts/check-dark-parity.js
fi

echo "✅ ADR-067チェック完了"
node "$(git rev-parse --show-toplevel)/frontend/scripts/check-claude-size.js"

# ── バックエンド Python 静的解析（ruff）────────────────────────────────────
# backend/app/ 配下の .py ファイルが変更された場合のみ実行。
# ruff 未インストールの場合は警告のみ（フロントエンドの lint-staged と同じ思想）。
BACKEND_PY_CHANGES=$(git diff --cached --name-only | grep -E "^backend/app/.*\.py$" || true)
if [ -n "$BACKEND_PY_CHANGES" ]; then
  echo "🐍 backend Python 変更検出 → ruff チェック..."
  cd "$(git rev-parse --show-toplevel)/backend"
  if command -v ruff >/dev/null 2>&1; then
    ruff check app/ --exit-zero
  else
    echo "⚠️  ruff 未インストール: pip install -r requirements-dev.txt を実行してください"
  fi
  cd "$(git rev-parse --show-toplevel)/frontend"
fi
