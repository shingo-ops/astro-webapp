#!/bin/sh
# worktree 外からのコミットを早期ブロック（push時より前に検知）
if [ -z "${GITHUB_ACTIONS}" ]; then
  GIT_COMMON_DIR="$(git rev-parse --git-common-dir 2>/dev/null)"
  case "${GIT_COMMON_DIR}" in
    /*) MAIN_REPO_ROOT="$(dirname "${GIT_COMMON_DIR}")" ;;
    *)  MAIN_REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" ;;
  esac
  CONFIG_FILE="${MAIN_REPO_ROOT}/.claude/agent-config.sh"
  # shellcheck source=.claude/agent-config.sh
  [ -f "${CONFIG_FILE}" ] && . "${CONFIG_FILE}"
  AGENT_WORKTREE_BASE="${AGENT_WORKTREE_BASE:-${HOME}/worktrees}"
  ACTUAL_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
  case "${ACTUAL_ROOT}" in
    "${AGENT_WORKTREE_BASE}/"*) ;;
    *)
      # active-work.md のみの変更（DONE更新等の管理作業）は例外として許可
      STAGED_FILES="$(git diff --cached --name-only 2>/dev/null)"
      NON_ADMIN_FILES=""
      if [ -n "${STAGED_FILES}" ]; then
        NON_ADMIN_FILES="$(printf '%s\n' "${STAGED_FILES}" | grep -v '^\.claude-pipeline/active-work\.md$' || true)"
      fi
      if [ -n "${NON_ADMIN_FILES}" ]; then
        echo ""
        echo "🚫 commit を中断しました: worktree 外での作業は禁止されています。"
        echo "   正しい手順: bash scripts/new-worktree.sh feature/morimoto/<トピック名>"
        echo ""
        exit 1
      fi
      ;;
  esac
fi

# ADR-067: ダークモード色規約の強制
# このフックはコミット前に以下のチェックを実行します:
#   1. ESLint — TSXインラインスタイルへのhex色禁止
#   2. CSS hex色チェック — App.css等のhex色禁止
#   3. ダークモード変数パリティチェック — :root と :root.force-dark の変数一致

# リポジトリルートを $0 から計算する（worktree + GIT_DIR 環境での
# git rev-parse --show-toplevel 再呼び出し誤動作を回避）
REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"

cd "$REPO_ROOT/frontend"

echo "🔍 ADR-067: ダークモード色規約チェック中..."

# lint-staged で変更ファイルのみチェック
npx lint-staged

# index.css が変更された場合はパリティチェック
if git diff --cached --name-only | grep -q "frontend/src/index.css"; then
  echo "📋 index.css 変更検出 → ダークモード変数パリティチェック実行"
  node scripts/check-dark-parity.js
fi

echo "✅ ADR-067チェック完了"
node "$REPO_ROOT/frontend/scripts/check-claude-size.js"

# ── バックエンド Python 静的解析（ruff）────────────────────────────────────
# backend/app/ 配下の .py ファイルが変更された場合のみ実行。
# ruff 未インストールの場合は警告のみ（フロントエンドの lint-staged と同じ思想）。
BACKEND_PY_CHANGES=$(git diff --cached --name-only | grep -E "^backend/app/.*\.py$" || true)
if [ -n "$BACKEND_PY_CHANGES" ]; then
  echo "🐍 backend Python 変更検出 → ruff チェック..."
  cd "$REPO_ROOT/backend"
  if command -v ruff >/dev/null 2>&1; then
    ruff check app/ --exit-zero
  else
    echo "❌ ruff 未インストール: cd backend && pip install -r requirements-dev.txt を実行してください"
    echo "   backend/app/ の変更をコミットするには ruff が必要です。"
    exit 1
  fi
  cd "$REPO_ROOT/frontend"
fi
