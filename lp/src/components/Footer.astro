---
const year = new Date().getFullYear();

const legalLinks = [
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Service' },
  { href: '/data-deletion', label: 'Data Deletion' },
];
---

<footer class="bg-brand-navy text-slate-400" style="border-top:1px solid rgba(255,255,255,0.06);">
  <div class="max-w-6xl mx-auto px-4 pt-12 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr] gap-10">
      <div>
        <a href="/" class="no-underline block mb-3" aria-label="Sales Anchor home">
          <img
            src="/logo.png"
            alt="Sales Anchor"
            class="h-8 w-auto"
            style="filter: brightness(0) invert(1);"
          />
        </a>
        <p class="text-sm leading-relaxed">
          The CRM built for cross-border TCG exporters.<br />
          Unify every channel, every customer, every deal.
        </p>
      </div>

      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-slate-200 mb-4">
          Operator
        </h4>
        <ul class="space-y-2 text-sm">
          <li>HIGH LIFE JPN</li>
          <li>Representative: Shingo Tanizawa</li>
          <li>2F, Nishi-Shinjuku Mizuma Building, 3-3-13 Nishi-Shinjuku, Shinjuku-ku, Tokyo 160-0023, Japan</li>
          <li>
            <a href="mailto:support@salesanchor.jp" class="text-slate-400 hover:text-white no-underline transition-colors">
              support@salesanchor.jp
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-slate-200 mb-4">
          Legal
        </h4>
        <ul class="space-y-2">
          {
            legalLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-slate-400 hover:text-white no-underline transition-colors">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 text-xs text-slate-500" style="border-top:1px solid rgba(255,255,255,0.08);">
      &copy; {year} HIGH LIFE JPN. All rights reserved.
    </div>
  </div>
</footer>
