---
const navItems = [
  { href: '/privacy', label: 'Privacy' },
  { href: '/terms', label: 'Terms' },
  { href: '/data-deletion', label: 'Data Deletion' },
];

const appUrl = 'https://app.salesanchor.jp';
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 h-20 flex items-center justify-between">
    <a href="/" class="no-underline flex items-center" aria-label="Sales Anchor home">
      <img src="/logo.png" alt="Sales Anchor" class="h-16 w-auto" />
    </a>

    <nav class="flex items-center gap-2 sm:gap-4">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="hidden sm:inline text-sm text-gray-600 hover:text-gray-900 no-underline transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
