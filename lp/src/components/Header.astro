---
const navItems = [
  { href: '/privacy', label: 'プライバシー' },
  { href: '/terms', label: '利用規約' },
  { href: '/data-deletion', label: 'データ削除' },
];

const appUrl = 'https://app.salesanchor.jp';
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="no-underline flex items-center" aria-label="Sales Anchor ホーム">
      <img src="/logo.png" alt="Sales Anchor" class="h-12 w-auto" />
    </a>

    <nav class="flex items-center gap-2 sm:gap-4">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="hidden sm:inline text-sm text-gray-700 hover:text-brand-600 no-underline"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={appUrl}
        class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 rounded-md no-underline transition-colors"
      >
        ログイン
      </a>
    </nav>
  </div>
</header>
