---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  {
    title: 'チャネル統合',
    description:
      'Messenger / Instagram / WhatsApp / LINE / Discord / Telegram / メール 等のメッセージを 1 画面で受信・返信。',
  },
  {
    title: '在庫構造化',
    description:
      'TCG 商品マスタを構造化（カード番号・拡張コード・レアリティ・言語・JAN）。',
  },
  {
    title: '請求自動化',
    description: '見積 → 請求 → 配送 → 注文の流れをワンクリックで進行。',
  },
  {
    title: 'AI 分析',
    description:
      '会話履歴・購買行動を Claude / GPT-5 で要約、次のアクションを提案。',
  },
];
---

<BaseLayout
  title="TCG輸出業者向け 統合 CRM"
  description="SalesAnchor は TCG 輸出業者向けの統合 CRM。Messenger / Instagram / WhatsApp / LINE / Discord / Telegram / メール 統合、在庫構造化、請求自動化、AI 分析。"
>
  <!-- A1. ヒーロー -->
  <section class="bg-gradient-to-br from-brand-50 via-white to-brand-50 py-20 md:py-28">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h1 class="sr-only">SalesAnchor — B2B Sales CRM &amp; Intelligence Platform</h1>
      <img
        src="/logo.png"
        alt=""
        role="presentation"
        class="mx-auto w-full max-w-xl md:max-w-2xl h-auto"
      />
      <p class="mt-8 text-xl md:text-2xl text-gray-700 max-w-2xl mx-auto">
        TCG 輸出業者のための統合 CRM
      </p>
      <p class="mt-4 text-base text-gray-600 max-w-xl mx-auto">
        Messenger / Instagram / WhatsApp / LINE / Discord / Telegram / メール 等を 1 画面に統合し、在庫構造化・請求自動化・AI 分析で大量取引を少人数チームでさばく B2B SaaS。
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://app.salesanchor.jp"
          class="inline-flex items-center justify-center px-8 py-3 text-base font-medium text-white bg-brand-600 hover:bg-brand-700 rounded-md no-underline transition-colors"
        >
          ログイン
        </a>
        <a
          href="#features"
          class="inline-flex items-center justify-center px-8 py-3 text-base font-medium text-brand-700 bg-white hover:bg-gray-50 border border-brand-200 rounded-md no-underline transition-colors"
        >
          機能を見る
        </a>
      </div>
    </div>
  </section>

  <!-- A2. 想定ユーザー -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
        想定ユーザー
      </h2>
      <p class="text-gray-700 leading-relaxed">
        SalesAnchor は、トレーディングカードゲーム（TCG）の B2B 輸出を事業として営む法人および個人事業主のために設計された CRM です。Messenger / Instagram / WhatsApp / LINE / Discord / Telegram / メール 等に分散した問い合わせ対応、TCG 特有の在庫管理（カード番号・拡張コード・レアリティ・言語・JAN）、見積から発送までの請求業務を 1 つのシステムに統合し、少人数チームでも数百件規模の取引を安定して処理できる運用基盤を提供します。
      </p>
    </div>
  </section>

  <!-- A3. 主要機能（4本柱）-->
  <section id="features" class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 text-center mb-12">
        主要機能
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          features.map((f) => (
            <div class="bg-white p-6 rounded-lg border border-gray-200 hover:border-brand-300 transition-colors">
              <h3 class="text-lg font-semibold text-brand-900">{f.title}</h3>
              <p class="mt-2 text-sm text-gray-700 leading-relaxed">{f.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- A4. Meta データ利用方針 -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
        Meta（Facebook / Instagram）データの取り扱い
      </h2>
      <p class="text-gray-700 leading-relaxed">
        SalesAnchor は、Messenger および Instagram Direct Message のメッセージを Meta Graph API 経由で受信し、テナント企業のオペレーター画面に表示します。受信したデータは Meta Platform Terms 第 3 条 (Data Use) に準拠し、以下の原則で取り扱います。
      </p>
      <ul class="mt-4 list-disc list-inside space-y-2 text-gray-700">
        <li>テナント企業とエンドユーザー間の通信仲介を目的とする利用に限定</li>
        <li>第三者への販売・広告ターゲティング目的での利用は行わない</li>
        <li>AI 学習データとして利用しない</li>
        <li>データ削除のご請求は Meta Platform 経由・メール経由の 2 通りでいつでも受付</li>
      </ul>
      <p class="mt-4">
        <a href="/privacy" class="text-brand-600 hover:text-brand-700">
          詳細はプライバシーポリシーをご覧ください →
        </a>
        &nbsp;
        <a href="/data-deletion" class="text-brand-600 hover:text-brand-700">
          データ削除のお申し込み →
        </a>
      </p>
    </div>
  </section>

  <!-- A5. データ保管・セキュリティ -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
        データ保管・セキュリティ
      </h2>
      <ul class="list-disc list-inside space-y-2 text-gray-700">
        <li>日本国内のデータセンター（さくらインターネット VPS）に保管、海外への転送なし</li>
        <li>通信経路は TLS 1.3 で暗号化（Let's Encrypt 証明書）</li>
        <li>アクセストークン等の機密情報は Fernet で暗号化保存</li>
        <li>PostgreSQL Row-Level Security によるテナント間データ完全分離</li>
        <li>Webhook 署名検証（HMAC-SHA256）による改ざん検知</li>
        <li>監査ログ取得・アクセス権限の最小化</li>
      </ul>
    </div>
  </section>

  <!-- A6. 運営者情報 -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
        運営者情報
      </h2>
      <dl class="space-y-3 text-gray-700">
        <div class="flex flex-col sm:flex-row sm:gap-4">
          <dt class="font-semibold text-gray-900 sm:w-32">事業者名</dt>
          <dd>HIGH LIFE JPN</dd>
        </div>
        <div class="flex flex-col sm:flex-row sm:gap-4">
          <dt class="font-semibold text-gray-900 sm:w-32">代表者</dt>
          <dd>Shingo Tanizawa</dd>
        </div>
        <div class="flex flex-col sm:flex-row sm:gap-4">
          <dt class="font-semibold text-gray-900 sm:w-32">所在地</dt>
          <dd>〒160-0023 東京都新宿区西新宿3丁目3番13号 西新宿水間ビル2F</dd>
        </div>
        <div class="flex flex-col sm:flex-row sm:gap-4">
          <dt class="font-semibold text-gray-900 sm:w-32">連絡先</dt>
          <dd><a href="mailto:support@salesanchor.jp" class="text-brand-600 hover:text-brand-700">support@salesanchor.jp</a></dd>
        </div>
        <div class="flex flex-col sm:flex-row sm:gap-4">
          <dt class="font-semibold text-gray-900 sm:w-32">対応時間</dt>
          <dd>月〜金 10:00 - 18:00 (JST) ／ 土日祝・年末年始・夏季休業を除く</dd>
        </div>
        <div class="flex flex-col sm:flex-row sm:gap-4">
          <dt class="font-semibold text-gray-900 sm:w-32">ウェブサイト</dt>
          <dd><a href="https://salesanchor.jp" class="text-brand-600 hover:text-brand-700">https://salesanchor.jp</a></dd>
        </div>
      </dl>
    </div>
  </section>
</BaseLayout>
