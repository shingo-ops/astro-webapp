---
import BaseLayout from '../layouts/BaseLayout.astro';

// ─── Background styles ──────────────────────────────────────────────────────
const heroBgStyle =
  "background: linear-gradient(135deg, rgba(10,22,40,0.92) 0%, rgba(10,22,40,0.75) 100%), url('https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=1600&q=80&auto=format') center/cover no-repeat;";

const ctaBgStyle =
  'background-color:#0a1628;background-image:radial-gradient(ellipse 80% 60% at 50% 50%, rgba(24,119,242,0.15) 0%, transparent 70%);';

const formCardShadow =
  'box-shadow: 0 25px 60px rgba(0,0,0,0.4), 0 8px 20px rgba(24,119,242,0.15);';

// ─── SVG icon helpers (stroke icons, 32×32) ─────────────────────────────────
// Problem band icons — white strokes for dark navy background
const svgProblems = [
  // Disconnected tools — broken chain link
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101"/>
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
    <line x1="6.5" y1="17.5" x2="17.5" y2="6.5" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round"/>
  </svg>`,
  // Cross-border complexity — globe
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="9" stroke="#ffffff" stroke-width="1.5"/>
    <path stroke="#ffffff" stroke-width="1.5"
      d="M3 12h18M12 3c-2.5 3-4 5.5-4 9s1.5 6 4 9M12 3c2.5 3 4 5.5 4 9s-1.5 6-4 9"/>
  </svg>`,
  // Small teams, hundreds of deals — lightning bolt
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
  </svg>`,
];

// Hub card icons — brand-blue strokes, rendered inside a light blue icon box
const svgHubs = [
  // Sales — bar chart
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M3 3v18h18M7 16v-4M11 16V9M15 16v-6M19 16V7"/>
  </svg>`,
  // Marketing — megaphone
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a4 4 0 000-8M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
  </svg>`,
  // Customer — chat bubbles
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
  </svg>`,
  // Data — database cylinders
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <ellipse cx="12" cy="5" rx="9" ry="3" stroke="#1877f2" stroke-width="1.5"/>
    <path stroke="#1877f2" stroke-width="1.5" d="M3 5v14c0 1.657 4.03 3 9 3s9-1.343 9-3V5"/>
    <path stroke="#1877f2" stroke-width="1.5" d="M3 12c0 1.657 4.03 3 9 3s9-1.343 9-3"/>
  </svg>`,
  // AI — circuit / cpu chip
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <rect x="7" y="7" width="10" height="10" rx="1" stroke="#1877f2" stroke-width="1.5"/>
    <path stroke="#1877f2" stroke-linecap="round" stroke-width="1.5"
      d="M9 7V4M12 7V4M15 7V4M9 20v-3M12 20v-3M15 20v-3M7 9H4M7 12H4M7 15H4M20 9h-3M20 12h-3M20 15h-3"/>
  </svg>`,
  // Catalog & Invoicing — package/box
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
  </svg>`,
];

// AI step icons — brand blue
const svgAiSteps = [
  // Deal AI — target/crosshair
  `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="9" stroke="#ffffff" stroke-width="1.5"/>
    <circle cx="12" cy="12" r="4" stroke="#ffffff" stroke-width="1.5"/>
    <line x1="12" y1="3" x2="12" y2="6" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="12" y1="18" x2="12" y2="21" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="3" y1="12" x2="6" y2="12" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="18" y1="12" x2="21" y2="12" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round"/>
  </svg>`,
  // Data AI — sparkles/clean
  `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M12 3v1M12 20v1M4.22 4.22l.7.7M19.07 19.07l.71.71M3 12H2M22 12h-1M4.93 19.07l-.71.71M19.78 4.93l-.71-.71"/>
    <circle cx="12" cy="12" r="4" stroke="#ffffff" stroke-width="1.5"/>
  </svg>`,
  // Customer AI — headset/support
  `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M12 2a9 9 0 00-9 9v1a3 3 0 003 3h1V11a3 3 0 10-1 0"/>
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M12 2a9 9 0 019 9v1a3 3 0 01-3 3h-1V11a3 3 0 10 1 0"/>
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M18 15v1a4 4 0 01-4 4h-4"/>
  </svg>`,
];

// ─── Data arrays ─────────────────────────────────────────────────────────────
const problemCards = [
  {
    svg: svgProblems[0],
    title: 'Disconnected tools',
    body: 'Email, spreadsheets, chat, and marketplaces — each with its own customer data. Nothing talks to anything else.',
  },
  {
    svg: svgProblems[1],
    title: 'Cross-border complexity',
    body: "Currency, time zones, language, and platform rules make every deal harder than it should be. Your CRM ignores all of it.",
  },
  {
    svg: svgProblems[2],
    title: 'Small teams, hundreds of deals',
    body: "You're moving fast without enough people. The follow-up falls through. The deal goes cold. It happens every week.",
  },
];

const hubCards = [
  {
    svg: svgHubs[0],
    title: 'Sales',
    body: 'Pipeline management that keeps every deal visible, every stage tracked.',
    bullets: [
      'Visual pipeline with drag-and-drop',
      'Customer record with full history',
      'Email + call log unified',
      'AI deal priority scoring',
      'Sales report & team goals',
      'Follow-up reminders',
    ],
    link: 'Explore Sales',
  },
  {
    svg: svgHubs[1],
    title: 'Marketing',
    body: "Capture leads, run campaigns, and measure what's actually working.",
    bullets: [
      'Lead capture forms',
      'Email campaigns & automation',
      'Social channel integration',
      'AI-generated content drafts',
      'Audience segmentation',
      'Marketing performance report',
    ],
    link: 'Explore Marketing',
  },
  {
    svg: svgHubs[2],
    title: 'Customer',
    body: 'Keep buyers happy and problems resolved — without losing context.',
    bullets: [
      'Support ticketing system',
      'AI chatbot (around the clock)',
      'NPS & satisfaction tracking',
      'Full interaction history',
      'SLA monitoring',
      'Escalation workflows',
    ],
    link: 'Explore Customer',
  },
  {
    svg: svgHubs[3],
    title: 'Data',
    body: 'One clean database for all your customers, products, and deals.',
    bullets: [
      'Unified CRM database',
      'Custom properties & fields',
      'API & platform integrations',
      'Data hygiene & deduplication',
      'Advanced segmentation',
      'Export & import tools',
    ],
    link: 'Explore Data',
  },
  {
    svg: svgHubs[4],
    title: 'AI',
    body: 'Automate the repetitive work. Focus on the deals that matter.',
    bullets: [
      'Conversation summaries',
      'Auto follow-up drafts',
      'Next best action suggestions',
      'Lead scoring & prioritization',
      'Sales forecast modeling',
      'Workflow automation',
    ],
    link: 'Explore AI',
  },
  {
    svg: svgHubs[5],
    title: 'Catalog & Invoicing',
    body: 'Product catalog, quotes, and invoices — all tied to the deal record.',
    bullets: [
      'Product catalog management',
      'Quote builder with PDF export',
      'Invoice tracking & reminders',
      'Multi-currency support',
      'Inventory status sync',
      'Deal-to-invoice linkage',
    ],
    link: 'Explore Catalog',
  },
];

const aiSteps = [
  {
    num: '1',
    svg: svgAiSteps[0],
    title: 'Deal AI — Never lose a lead',
    body: 'AI scores and prioritizes every inbound inquiry. The next action surfaces automatically — draft reply, schedule call, or escalate to a team member.',
  },
  {
    num: '2',
    svg: svgAiSteps[1],
    title: 'Data AI — Clean as you go',
    body: 'Duplicate contacts, outdated records, missing fields — AI flags and resolves them in the background, keeping your CRM accurate without manual cleanup.',
  },
  {
    num: '3',
    svg: svgAiSteps[2],
    title: 'Customer AI — Resolve buyer inquiries around the clock',
    body: 'AI handles common buyer questions automatically, around the clock. Complex issues are escalated with full context — no buyer starts over.',
  },
];

// AI Performance Metrics card data
const aiMetrics = [
  {
    label: 'Inquiries resolved automatically',
    value: '65%',
    bar: '65%',
    // SVG: lightning bolt
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" aria-hidden="true"><path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  },
  {
    label: 'Faster deal follow-through',
    value: '3× speed',
    bar: '80%',
    // SVG: arrow up-right
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" aria-hidden="true"><path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10"/></svg>`,
  },
  {
    label: 'Lead scoring accuracy',
    value: '89%',
    bar: '89%',
    // SVG: crosshair/target
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="#1877f2" stroke-width="1.5"/><circle cx="12" cy="12" r="3" stroke="#1877f2" stroke-width="1.5"/><line x1="12" y1="3" x2="12" y2="7" stroke="#1877f2" stroke-width="1.5" stroke-linecap="round"/><line x1="12" y1="17" x2="12" y2="21" stroke="#1877f2" stroke-width="1.5" stroke-linecap="round"/><line x1="3" y1="12" x2="7" y2="12" stroke="#1877f2" stroke-width="1.5" stroke-linecap="round"/><line x1="17" y1="12" x2="21" y2="12" stroke="#1877f2" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    label: 'B2B deals on one platform',
    value: '100s',
    bar: '72%',
    // SVG: globe
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="#1877f2" stroke-width="1.5"/><path stroke="#1877f2" stroke-width="1.5" d="M3 12h18M12 3c-2.5 3-4 5.5-4 9s1.5 6 4 9M12 3c2.5 3 4 5.5 4 9s-1.5 6-4 9"/></svg>`,
  },
];
---

<BaseLayout
  title="The CRM built for cross-border TCG exporters"
  description="Stop juggling Excel tabs, DMs, and invoices. Sales Anchor gives TCG exporters one place to unify every channel, manage catalog, and automate invoicing — so a small team can handle hundreds of B2B deals without losing track."
>
  <!-- S1. Hero — Dark Navy + Unsplash background image + Blue Glow -->
  <section class="text-slate-100 py-20 md:py-24" style={heroBgStyle}>
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_420px] gap-12 items-center">

        <!-- Left: Copy -->
        <div>
          <span
            class="inline-block rounded-full border px-3.5 py-1 text-xs font-semibold uppercase tracking-widest text-blue-300 mb-6"
            style="background:rgba(24,119,242,0.18);border-color:rgba(24,119,242,0.35);"
          >
            B2B CRM &middot; Cross-border TCG
          </span>
          <h1 class="font-serif font-normal text-white leading-tight text-[34px] sm:text-5xl lg:text-6xl mb-6">
            The game changer<br />
            isn't your spreadsheet.<br />
            <em class="italic text-brand-500" role="presentation">It's context.</em>
          </h1>
          <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-8 max-w-[480px]">
            The CRM built for cross-border TCG exporters.
            Unify every channel, customer, and deal — then let AI handle the follow-through.
          </p>
          <div class="flex flex-wrap gap-2.5">
            <span
              class="inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 text-xs text-slate-200"
              style="background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.15);"
            >
              <span class="font-medium text-slate-400">Built for:</span> TCG Exporters
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 text-xs text-slate-200"
              style="background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.15);"
            >
              <span class="font-medium text-slate-400">Workflow:</span> Zero Excel tabs
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 text-xs text-slate-200"
              style="background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.15);"
            >
              <span class="font-medium text-slate-400">Scale:</span> 100s of B2B deals
            </span>
          </div>
        </div>

        <!-- Right: Form card -->
        <div
          class="bg-white text-gray-900 rounded-3xl p-8 max-w-[480px] w-full justify-self-center lg:justify-self-end"
          style={formCardShadow}
        >
          <h2 class="font-serif text-2xl font-normal mb-1">Request a brochure</h2>
          <p class="text-sm text-gray-500 mb-5">Our team will follow up shortly.</p>
          <form
            action="mailto:support@salesanchor.jp?subject=Brochure%20request"
            method="post"
            enctype="text/plain"
          >
            <div class="space-y-3.5">
              <div>
                <label for="name" class="block text-xs font-semibold text-gray-900 mb-1.5">
                  Name <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="Name"
                  required
                  placeholder="Your name"
                  class="w-full px-3 py-2.5 border-[1.5px] border-gray-200 rounded-lg text-sm focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20"
                />
              </div>
              <div>
                <label for="company" class="block text-xs font-semibold text-gray-900 mb-1.5">
                  Company <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="company"
                  name="Company"
                  required
                  placeholder="Company name"
                  class="w-full px-3 py-2.5 border-[1.5px] border-gray-200 rounded-lg text-sm focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20"
                />
              </div>
              <div>
                <label for="email" class="block text-xs font-semibold text-gray-900 mb-1.5">
                  Email <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="Email"
                  required
                  placeholder="you@company.com"
                  class="w-full px-3 py-2.5 border-[1.5px] border-gray-200 rounded-lg text-sm focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20"
                />
              </div>
              <div>
                <label for="phone" class="block text-xs font-semibold text-gray-900 mb-1.5">
                  Phone
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="Phone"
                  placeholder="+1 000 000 0000"
                  class="w-full px-3 py-2.5 border-[1.5px] border-gray-200 rounded-lg text-sm focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20"
                />
              </div>
              <div>
                <label for="size" class="block text-xs font-semibold text-gray-900 mb-1.5">
                  Company size
                </label>
                <select
                  id="size"
                  name="Company size"
                  class="w-full px-3 py-2.5 border-[1.5px] border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20"
                >
                  <option value="">Select…</option>
                  <option value="1-10">1–10</option>
                  <option value="11-50">11–50</option>
                  <option value="51-200">51–200</option>
                  <option value="201-500">201–500</option>
                  <option value="501+">501+</option>
                </select>
              </div>
              <button
                type="submit"
                class="w-full mt-1 py-3 px-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors text-sm"
              >
                Send request →
              </button>
            </div>
          </form>
          <p class="mt-3 text-xs text-gray-500 text-center">
            Our team will follow up shortly.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- S2. Problem Band — Dark Navy background -->
  <section class="py-16 md:py-20" style="background-color:#0f1f3d;">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-center text-blue-400 text-xs font-bold tracking-widest uppercase mb-3">
        The problem
      </p>
      <h2 class="font-serif font-normal text-center text-3xl md:text-4xl leading-tight mb-3 text-white">
        Why most CRMs fail cross-border teams
      </h2>
      <p class="text-center text-slate-400 text-base mb-10 max-w-2xl mx-auto">
        Your business is global and fast. Your tools weren't built for it.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          problemCards.map((card) => (
            <div class="rounded-2xl p-7 border" style="background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.1);">
              <span class="block mb-4" set:html={card.svg} />
              <h3 class="text-lg font-bold text-white mb-2">{card.title}</h3>
              <p class="text-sm text-slate-400 leading-relaxed">{card.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- S3. Hub Card Grid — off-white background -->
  <section class="py-20" style="background-color:#f8fafc;">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-center text-brand-500 text-xs font-bold tracking-widest uppercase mb-3">
        The platform
      </p>
      <h2 class="font-serif font-normal text-center text-3xl md:text-4xl leading-tight mb-3 text-gray-900">
        Everything your team needs, finally unified
      </h2>
      <p class="text-center text-gray-500 text-base mb-10 max-w-2xl mx-auto">
        Six hubs. One system. Built for how cross-border exporters actually work.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          hubCards.map((card) => (
            <div class="group relative overflow-hidden bg-white rounded-2xl border-[1.5px] border-gray-200 p-8 transition-all duration-200 hover:border-brand-500 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(24,119,242,0.12)]">
              <span class="absolute inset-x-0 top-0 h-[3px] bg-brand-500 opacity-0 transition-opacity duration-200 group-hover:opacity-100" aria-hidden="true"></span>
              <div class="w-11 h-11 rounded-xl bg-blue-50 flex items-center justify-center mb-4">
                <span set:html={card.svg} />
              </div>
              <h3 class="text-base font-bold text-gray-900 mb-2">{card.title}</h3>
              <p class="text-sm text-gray-500 leading-relaxed mb-5">{card.body}</p>
              <ul class="list-none space-y-1 mb-6">
                {
                  card.bullets.map((bullet) => (
                    <li class="relative pl-4 text-xs text-gray-500 leading-relaxed before:absolute before:left-0 before:top-0 before:text-brand-500 before:font-bold before:content-['✓']">
                      {bullet}
                    </li>
                  ))
                }
              </ul>
              <a
                href="#"
                class="inline-flex items-center gap-1 text-sm font-semibold text-brand-500 hover:text-brand-600 no-underline"
              >
                {card.link} →
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- S4. AI Split Section — light blue background -->
  <section class="py-20" style="background-color:#f0f6ff;">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Left: Steps -->
        <div>
          <p class="text-brand-500 text-xs font-bold tracking-widest uppercase mb-3">
            AI Automation
          </p>
          <h2 class="font-serif font-normal text-3xl md:text-4xl leading-tight text-gray-900 mb-2">
            Your AI-powered<br />sales team, always on
          </h2>
          <p class="text-gray-500 text-base mb-8 leading-relaxed">
            From the first inquiry to the closed deal, AI handles the follow-through so your team can focus on relationships.
          </p>
          <div class="flex flex-col gap-6">
            {
              aiSteps.map((step) => (
                <div class="flex gap-4 items-start">
                  <div class="shrink-0 w-9 h-9 rounded-full bg-brand-500 text-white text-sm font-bold flex items-center justify-center">
                    <span set:html={step.svg} />
                  </div>
                  <div>
                    <h3 class="text-base font-bold text-gray-900 mb-1">{step.title}</h3>
                    <p class="text-sm text-gray-500 leading-relaxed">{step.body}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Right: AI Performance Metrics card -->
        <div class="bg-white rounded-2xl p-9 shadow-2xl border border-gray-100">
          <p class="text-xs font-bold tracking-widest uppercase text-brand-500 mb-6">
            AI Performance Metrics
          </p>
          {
            aiMetrics.map((m) => (
              <div class="py-5 border-b border-gray-100 last:border-0 last:pb-0 flex gap-4 items-start">
                <div class="w-11 h-11 rounded-xl bg-blue-50 flex items-center justify-center shrink-0">
                  <span set:html={m.iconSvg} />
                </div>
                <div class="flex-1">
                  <p class="text-xs text-gray-400 mb-1">{m.label}</p>
                  <p class="font-serif text-2xl text-brand-500 leading-none">{m.value}</p>
                  <div class="h-1 bg-gray-100 rounded mt-2">
                    <div
                      class="h-full rounded"
                      style={`width:${m.bar};background:linear-gradient(90deg,#1877f2,#60a5fa);`}
                    />
                  </div>
                </div>
              </div>
            ))
          }
        </div>

      </div>
    </div>
  </section>

  <!-- S5. Closing CTA — Dark Navy -->
  <section class="text-slate-100 py-24 text-center" style={ctaBgStyle}>
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-serif font-normal text-white text-3xl md:text-4xl lg:text-5xl leading-tight mb-4">
        Ready to close more deals<br />across borders?
      </h2>
      <p class="text-slate-300 text-base md:text-lg max-w-xl mx-auto mb-10">
        Sales Anchor brings your channels, customers, and workflows into one place —
        then puts AI to work so your team can do more with less.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="mailto:support@salesanchor.jp?subject=Brochure%20request"
          class="inline-flex items-center px-8 py-3.5 bg-brand-500 hover:bg-brand-600 text-white text-base font-semibold rounded-lg no-underline transition-all hover:-translate-y-px"
        >
          Request a brochure →
        </a>
        <a
          href="https://app.salesanchor.jp"
          class="inline-flex items-center px-8 py-3.5 text-white text-base font-semibold rounded-lg no-underline border-[1.5px] transition-colors"
          style="background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.25);"
        >
          Sign in to Sales Anchor
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
