---
import BaseLayout from '../layouts/BaseLayout.astro';

// ─── Background styles ──────────────────────────────────────────────────────
const heroBgStyle =
  "background: linear-gradient(135deg, rgba(10,22,40,0.92) 0%, rgba(10,22,40,0.75) 100%), url('https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=1600&q=80&auto=format') center/cover no-repeat;";

const ctaBgStyle =
  'background:linear-gradient(155deg,#060d1f 0%,#0a1628 45%,#0e2040 100%);' +
  'background-image:radial-gradient(ellipse 75% 55% at 50% 45%,rgba(24,119,242,0.28) 0%,transparent 68%),' +
  'radial-gradient(ellipse 35% 40% at 15% 85%,rgba(99,102,241,0.12) 0%,transparent 55%);';

const formCardShadow =
  'box-shadow: 0 25px 60px rgba(0,0,0,0.4), 0 8px 20px rgba(24,119,242,0.15);';

// ─── SVG icon helpers ────────────────────────────────────────────────────────
const svgProblems = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101"/>
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
    <line x1="6.5" y1="17.5" x2="17.5" y2="6.5" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round"/>
  </svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="9" stroke="#ffffff" stroke-width="1.5"/>
    <path stroke="#ffffff" stroke-width="1.5"
      d="M3 12h18M12 3c-2.5 3-4 5.5-4 9s1.5 6 4 9M12 3c2.5 3 4 5.5 4 9s-1.5 6-4 9"/>
  </svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
  </svg>`,
];

const svgHubs = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M3 3v18h18M7 16v-4M11 16V9M15 16v-6M19 16V7"/>
  </svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
  </svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a4 4 0 000-8M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
  </svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <ellipse cx="12" cy="5" rx="9" ry="3" stroke="#1877f2" stroke-width="1.5"/>
    <path stroke="#1877f2" stroke-width="1.5" d="M3 5v14c0 1.657 4.03 3 9 3s9-1.343 9-3V5"/>
    <path stroke="#1877f2" stroke-width="1.5" d="M3 12c0 1.657 4.03 3 9 3s9-1.343 9-3"/>
  </svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <rect x="7" y="7" width="10" height="10" rx="1" stroke="#1877f2" stroke-width="1.5"/>
    <path stroke="#1877f2" stroke-linecap="round" stroke-width="1.5"
      d="M9 7V4M12 7V4M15 7V4M9 20v-3M12 20v-3M15 20v-3M7 9H4M7 12H4M7 15H4M20 9h-3M20 12h-3M20 15h-3"/>
  </svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
  </svg>`,
];

const svgAiSteps = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="9" stroke="#ffffff" stroke-width="1.5"/>
    <circle cx="12" cy="12" r="4" stroke="#ffffff" stroke-width="1.5"/>
    <line x1="12" y1="3" x2="12" y2="6" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="12" y1="18" x2="12" y2="21" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="3" y1="12" x2="6" y2="12" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="18" y1="12" x2="21" y2="12" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round"/>
  </svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M12 3v1M12 20v1M4.22 4.22l.7.7M19.07 19.07l.71.71M3 12H2M22 12h-1M4.93 19.07l-.71.71M19.78 4.93l-.71-.71"/>
    <circle cx="12" cy="12" r="4" stroke="#ffffff" stroke-width="1.5"/>
  </svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke="#ffffff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
      d="M3 11l19-9-9 19-2-8-8-2z"/>
  </svg>`,
];

// ─── Data arrays ─────────────────────────────────────────────────────────────
const hubCards = [
  {
    svg: svgHubs[0],
    title: 'Sales',
    body: 'Pipeline management that keeps every deal visible, every stage tracked.',
    bullets: [
      'Visual pipeline with drag-and-drop',
      'Customer record with full history',
      'Email + call log unified',
      'AI deal priority scoring',
      'Sales report & team goals',
      'Follow-up reminders',
    ],
    link: 'Explore Sales',
  },
  {
    svg: svgHubs[1],
    title: 'Messaging',
    body: 'Messenger, Instagram DM, and email — unified in one inbox via Meta\'s official API.',
    bullets: [
      'Facebook Messenger integration',
      'Instagram Direct Messages',
      'Email & multi-channel inbox',
      'Human Agent tag support',
      'Full conversation history',
      'Auto reply drafts with AI',
    ],
    link: 'Explore Messaging',
    metaBadge: true,
  },
  {
    svg: svgHubs[2],
    title: 'Marketing',
    body: 'Capture leads, run campaigns, and measure what\'s actually working.',
    bullets: [
      'Lead capture forms',
      'Email campaigns & automation',
      'Social channel integration',
      'AI-generated content drafts',
      'Audience segmentation',
      'Marketing performance report',
    ],
    link: 'Explore Marketing',
  },
  {
    svg: svgHubs[3],
    title: 'Data',
    body: 'One clean database for all your customers, products, and deals.',
    bullets: [
      'Unified CRM database',
      'Custom properties & fields',
      'API & platform integrations',
      'Data hygiene & deduplication',
      'Advanced segmentation',
      'Export & import tools',
    ],
    link: 'Explore Data',
  },
  {
    svg: svgHubs[4],
    title: 'AI',
    body: 'Automate the repetitive work. Focus on the deals that matter.',
    bullets: [
      'Conversation summaries',
      'Auto follow-up drafts',
      'Next best action suggestions',
      'Lead scoring & prioritization',
      'Sales forecast modeling',
      'Workflow automation',
    ],
    link: 'Explore AI',
  },
  {
    svg: svgHubs[5],
    title: 'Catalog & Invoicing',
    body: 'Product catalog, quotes, and invoices — all tied to the deal record.',
    bullets: [
      'Product catalog management',
      'Quote builder with PDF export',
      'Invoice tracking & reminders',
      'Multi-currency support',
      'Inventory status sync',
      'Deal-to-invoice linkage',
    ],
    link: 'Explore Catalog',
  },
];

const aiSteps = [
  {
    num: '1',
    svg: svgAiSteps[0],
    title: 'Deal AI — Never lose a lead',
    body: 'AI scores and prioritizes every inbound inquiry. The next action surfaces automatically — draft reply, schedule call, or escalate to a team member.',
  },
  {
    num: '2',
    svg: svgAiSteps[1],
    title: 'Data AI — Clean as you go',
    body: 'Duplicate contacts, outdated records, missing fields — AI flags and resolves them in the background, keeping your CRM accurate without manual cleanup.',
  },
  {
    num: '3',
    svg: svgAiSteps[2],
    title: 'Customer AI — Resolve buyer inquiries around the clock',
    body: 'AI handles common buyer questions automatically, around the clock. Complex issues are escalated with full context — no buyer starts over.',
  },
];

const aiMetrics = [
  {
    label: 'Inquiries resolved automatically',
    value: '65%',
    bar: '65%',
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" aria-hidden="true"><path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  },
  {
    label: 'Faster deal follow-through',
    value: '3× speed',
    bar: '80%',
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" aria-hidden="true"><path stroke="#1877f2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10"/></svg>`,
  },
  {
    label: 'Lead scoring accuracy',
    value: '89%',
    bar: '89%',
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="#1877f2" stroke-width="1.5"/><circle cx="12" cy="12" r="3" stroke="#1877f2" stroke-width="1.5"/><line x1="12" y1="3" x2="12" y2="7" stroke="#1877f2" stroke-width="1.5" stroke-linecap="round"/><line x1="12" y1="17" x2="12" y2="21" stroke="#1877f2" stroke-width="1.5" stroke-linecap="round"/><line x1="3" y1="12" x2="7" y2="12" stroke="#1877f2" stroke-width="1.5" stroke-linecap="round"/><line x1="17" y1="12" x2="21" y2="12" stroke="#1877f2" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    label: 'B2B deals on one platform',
    value: '100s',
    bar: '72%',
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="#1877f2" stroke-width="1.5"/><path stroke="#1877f2" stroke-width="1.5" d="M3 12h18M12 3c-2.5 3-4 5.5-4 9s1.5 6 4 9M12 3c2.5 3 4 5.5 4 9s-1.5 6-4 9"/></svg>`,
  },
];

const faqItems = [
  {
    q: 'What channels does Sales Anchor support?',
    a: 'Messenger, Instagram Direct Messages, email, and more. We connect to Facebook Pages and Instagram Business Accounts via Meta\'s official API.',
  },
  {
    q: 'Why does Sales Anchor need access to my Facebook Page?',
    a: 'To receive and reply to Messenger messages from your buyers on your behalf. We only access messages on Pages you explicitly connect and authorize through Meta Login.',
  },
  {
    q: 'How is my data handled?',
    a: 'All data is stored on Japan-based servers (SAKURA internet Inc.), encrypted with TLS 1.3 in transit and Fernet encryption at rest. We never sell or share your data with third parties.',
  },
  {
    q: 'Can I delete my data?',
    a: 'Yes, at any time. Submit a request via email or our Data Deletion page and we will complete full deletion within 30 days. You can also revoke access directly from your Facebook settings.',
  },
  {
    q: 'Is there a free trial?',
    a: 'Yes — 14 days free with full access. No credit card required to start.',
  },
  {
    q: 'How long does onboarding take?',
    a: 'Most teams are fully set up within 2 hours. Our support team is available Monday–Friday 10:00–18:00 JST to guide you through the process.',
  },
  {
    q: 'Does Sales Anchor support Instagram DMs?',
    a: 'Yes. Sales Anchor integrates with Instagram Direct Messages via the Instagram Messaging API for Business accounts connected to a Facebook Page.',
  },
];
---

<BaseLayout
  title="The CRM built for cross-border TCG exporters"
  description="Stop juggling Excel tabs, DMs, and invoices. Sales Anchor gives TCG exporters one place to unify every channel, manage catalog, and automate invoicing — so a small team can handle hundreds of B2B deals without losing track."
>

  <!-- ═══════════════════════════════════════════════════════════════════════
       S1. Hero — Dual CTA + simplified form
  ════════════════════════════════════════════════════════════════════════════ -->
  <section class="text-slate-100 py-20 md:py-24" style={heroBgStyle}>
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_400px] gap-12 items-center">

        <!-- Left: Copy + CTAs -->
        <div>
          <span
            class="inline-block rounded-full border px-3.5 py-1 text-xs font-semibold uppercase tracking-widest text-blue-300 mb-6"
            style="background:rgba(24,119,242,0.18);border-color:rgba(24,119,242,0.35);"
          >
            B2B CRM &middot; Cross-border TCG
          </span>
          <h1 class="font-serif font-normal text-white leading-tight text-[34px] sm:text-5xl lg:text-[3.25rem] mb-5">
            Close more cross-border deals.<br />
            <em class="italic text-brand-500" role="presentation">Without the chaos.</em>
          </h1>
          <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-8 max-w-[500px]">
            Sales Anchor unifies every buyer conversation — Messenger, Instagram DM, and email —
            into one CRM built specifically for cross-border TCG exporters.
            AI handles the follow-through.
          </p>

          <!-- Dual CTA -->
          <div class="flex flex-wrap gap-3 mb-8">
            <a
              href="#request-brochure"
              class="inline-flex items-center px-6 py-3 bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold rounded-lg no-underline transition-all hover:-translate-y-px"
            >
              Request early access →
            </a>
            <a
              href="mailto:support@salesanchor.jp?subject=Demo%20Request"
              class="inline-flex items-center px-6 py-3 text-white text-sm font-semibold rounded-lg no-underline transition-all hover:-translate-y-px border"
              style="background:rgba(255,255,255,0.1);border-color:rgba(255,255,255,0.25);"
            >
              Contact sales ↗
            </a>
          </div>

          <!-- Badges -->
          <div class="flex flex-wrap gap-2.5">
            <span
              class="inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 text-xs text-slate-200"
              style="background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.15);"
            >
              <span class="text-green-400">✓</span> TCG Exporters
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 text-xs text-slate-200"
              style="background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.15);"
            >
              <span class="text-green-400">✓</span> Messenger + Instagram
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 text-xs text-slate-200"
              style="background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.15);"
            >
              <span class="text-green-400">✓</span> AI-powered
            </span>
          </div>
        </div>

        <!-- Right: Form card -->
        <div
          id="request-brochure"
          class="bg-white text-gray-900 rounded-3xl p-8 max-w-[440px] w-full justify-self-center lg:justify-self-end"
          style={formCardShadow}
        >
          <h2 class="font-serif text-2xl font-normal mb-1">Request early access</h2>
          <p class="text-sm text-gray-500 mb-5">Our team will follow up within 24 hours.</p>
          <form
            id="contact-form"
            action="https://api.salesanchor.jp/api/v1/contact"
            method="POST"
          >
            <div class="space-y-3.5">
              <div>
                <label for="name" class="block text-xs font-semibold text-gray-900 mb-1.5">
                  Name <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Your name"
                  class="w-full px-3 py-2.5 border-[1.5px] border-gray-200 rounded-lg text-sm focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20"
                />
              </div>
              <div>
                <label for="email" class="block text-xs font-semibold text-gray-900 mb-1.5">
                  Work email <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="you@company.com"
                  class="w-full px-3 py-2.5 border-[1.5px] border-gray-200 rounded-lg text-sm focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20"
                />
              </div>
              <div>
                <label for="company" class="block text-xs font-semibold text-gray-900 mb-1.5">
                  Company <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  required
                  placeholder="Company name"
                  class="w-full px-3 py-2.5 border-[1.5px] border-gray-200 rounded-lg text-sm focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20"
                />
              </div>
              <button
                type="submit"
                id="submit-btn"
                class="w-full mt-1 py-3 px-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-lg transition-colors text-sm"
              >
                Send request →
              </button>
            </div>
            <div id="form-success" class="hidden mt-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700 text-center">
              ✓ Request sent! We'll follow up within 24 hours.
            </div>
            <div id="form-error" class="hidden mt-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700 text-center">
              Something went wrong. Please email us at support@salesanchor.jp
            </div>
          </form>
          <p class="mt-3 text-xs text-gray-400 text-center">
            No credit card required. Early-access pricing available.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       S2. Product Facts Band — white, Hero直下
       製品の実装済み事実のみ掲載（ローンチ前フェーズ）
  ════════════════════════════════════════════════════════════════════════════ -->
  <section class="py-10 border-b border-gray-100 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-center text-xs font-semibold uppercase tracking-widest text-gray-400 mb-8">
        Built for cross-border TCG exporters
      </p>
      <div class="flex flex-wrap justify-center gap-6 md:gap-12 items-start">
        <div class="text-center max-w-[140px]">
          <p class="font-serif text-3xl font-normal text-brand-500">6</p>
          <p class="text-xs text-gray-500 mt-1 leading-snug">Integrated channels<br/><span class="text-gray-400">(Messenger, IG DM, email +)</span></p>
        </div>
        <div class="text-center max-w-[140px]">
          <p class="font-serif text-3xl font-normal text-brand-500">14 days</p>
          <p class="text-xs text-gray-500 mt-1 leading-snug">Free trial<br/><span class="text-gray-400">No credit card required</span></p>
        </div>
        <div class="text-center max-w-[140px]">
          <p class="font-serif text-3xl font-normal text-brand-500">&lt; 2 hrs</p>
          <p class="text-xs text-gray-500 mt-1 leading-snug">To full setup<br/><span class="text-gray-400">Guided onboarding</span></p>
        </div>
        <div class="text-center max-w-[140px]">
          <p class="font-serif text-3xl font-normal text-brand-500">24/7</p>
          <p class="text-xs text-gray-500 mt-1 leading-snug">AI automation<br/><span class="text-gray-400">Always on, never misses</span></p>
        </div>
        <div class="text-center max-w-[140px]">
          <p class="font-serif text-3xl font-normal text-brand-500">Meta</p>
          <p class="text-xs text-gray-500 mt-1 leading-snug">Official API<br/><span class="text-gray-400">Messenger + Instagram</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       S3. Problem → Solution Band — Dark Navy
       顧客向け: 共感→期待 / Meta向け: 使用文脈の説明
  ════════════════════════════════════════════════════════════════════════════ -->
  <section class="py-16 md:py-20" style="background-color:#0f1f3d;">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-center text-blue-400 text-xs font-bold tracking-widest uppercase mb-3">
        The challenge
      </p>
      <h2 class="font-serif font-normal text-center text-3xl md:text-4xl leading-tight mb-3 text-white">
        Cross-border TCG sales is uniquely hard.
      </h2>
      <p class="text-center text-slate-400 text-base mb-12 max-w-2xl mx-auto">
        Sales Anchor is built for exactly this.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <div class="rounded-2xl p-7 border" style="background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.1);">
          <span class="block mb-4" set:html={svgProblems[0]} />
