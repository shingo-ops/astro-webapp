---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  {
    title: 'Unified Inbox',
    description:
      'Messenger, Instagram, WhatsApp, LINE, Discord, Telegram, and email — all in one screen. No tab switching, no missed messages.',
  },
  {
    title: 'Structured Catalog',
    description:
      'TCG product master with card number, set code, rarity, language, and JAN. Stop managing inventory in spreadsheets.',
  },
  {
    title: 'Automated Invoicing',
    description:
      'Move from quote to invoice to shipment to order with a single click. Built for the volume of B2B TCG trade.',
  },
  {
    title: 'AI Insights',
    description:
      'Conversation history and purchase behavior summarized by Claude. Surface the next best action before you ask.',
  },
];
---

<BaseLayout
  title="The CRM built for cross-border TCG exporters"
  description="Sales Anchor is a multi-channel CRM for B2B Trading Card Game exporters. Unified inbox, structured catalog, automated invoicing, and AI insights — built for the volume of cross-border trade."
>
  <!-- A1. Hero -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h1 class="sr-only">Sales Anchor — B2B CRM for Cross-Border TCG Exporters</h1>
      <img
        src="/logo.png"
        alt=""
        role="presentation"
        class="mx-auto w-full max-w-xl md:max-w-2xl h-auto"
      />
      <p class="mt-10 text-3xl md:text-4xl font-semibold text-gray-900 tracking-tight max-w-2xl mx-auto leading-tight">
        The CRM built for cross-border TCG exporters.
      </p>
      <p class="mt-5 text-lg text-gray-500 max-w-xl mx-auto leading-relaxed">
        Unify every channel, structure your catalog, automate invoicing, and let AI surface the next
        best action — so a small team can handle hundreds of B2B deals without losing track.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="mailto:support@salesanchor.jp?subject=Demo%20request"
          class="inline-flex items-center justify-center px-7 py-3 text-base font-medium text-white bg-gray-900 hover:bg-gray-700 rounded-md no-underline transition-colors"
        >
          Book a demo
        </a>
        <a
          href="https://app.salesanchor.jp"
          class="inline-flex items-center justify-center px-7 py-3 text-base font-medium text-gray-700 bg-white hover:bg-gray-50 border border-gray-300 rounded-md no-underline transition-colors"
        >
          Sign in
        </a>
      </div>
    </div>
  </section>

  <!-- A2. Who it's for -->
  <section class="py-20 bg-gray-50 border-y border-gray-100">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-5">
        Who it's for
      </h2>
      <p class="text-gray-600 leading-relaxed text-lg">
        Sales Anchor is built for companies and sole proprietors who export Trading Card Game products
        to overseas buyers. You manage inquiries from a dozen channels simultaneously — Messenger,
        Instagram, WhatsApp, LINE, Discord, Telegram, email — while tracking card-level inventory
        (set code, rarity, language, JAN) and processing invoices for hundreds of orders per month.
        Sales Anchor brings all of that into one system, so a lean team can operate at scale without
        dropping threads.
      </p>
    </div>
  </section>

  <!-- A3. Features -->
  <section id="features" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-semibold text-gray-900 text-center mb-14">
        Features
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          features.map((f) => (
            <div class="p-6 rounded-xl border border-gray-200 hover:border-gray-300 transition-colors">
              <h3 class="text-base font-semibold text-gray-900">{f.title}</h3>
              <p class="mt-2 text-sm text-gray-500 leading-relaxed">{f.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- A4. How we use Meta data -->
  <section class="py-20 bg-gray-50 border-y border-gray-100">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-5">
        How we use Meta data
      </h2>
      <p class="text-gray-600 leading-relaxed">
        Sales Anchor receives messages from Messenger and Instagram Direct Message via the Meta Graph
        API and displays them in the operator's dashboard. All data obtained from Meta Platform is
        handled in strict accordance with the following principles:
      </p>
      <ul class="mt-5 space-y-3 text-gray-600">
        <li class="flex gap-3">
          <span class="mt-1 text-gray-400 shrink-0">—</span>
          <span>Used solely to facilitate communication between client companies and their customers.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 text-gray-400 shrink-0">—</span>
          <span>Compliant with Article 3 (Data Use) of the Meta Platform Terms.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 text-gray-400 shrink-0">—</span>
          <span>Never sold to third parties or used for advertising targeting.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 text-gray-400 shrink-0">—</span>
          <span>Never used as AI training data.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 text-gray-400 shrink-0">—</span>
          <span>Data deletion requests accepted both via Meta Platform and direct email.</span>
        </li>
      </ul>
      <div class="mt-6 flex gap-6 text-sm">
        <a href="/privacy" class="text-gray-900 hover:text-gray-600 font-medium no-underline">
          Privacy Policy →
        </a>
        <a href="/data-deletion" class="text-gray-900 hover:text-gray-600 font-medium no-underline">
          Data Deletion →
        </a>
      </div>
    </div>
  </section>

  <!-- A5. Security & infrastructure -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-5">
        Security &amp; infrastructure
      </h2>
      <ul class="space-y-3 text-gray-600">
        <li class="flex gap-3">
          <span class="mt-1 text-gray-400 shrink-0">—</span>
          <span>All data stored on servers located in Japan (SAKURA internet VPS). No transfer outside Japan.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 text-gray-400 shrink-0">—</span>
          <span>All traffic encrypted with TLS 1.3 (Let's Encrypt certificate).</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 text-gray-400 shrink-0">—</span>
          <span>Sensitive credentials (access tokens, etc.) encrypted at rest with Fernet symmetric encryption.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 text-gray-400 shrink-0">—</span>
          <span>PostgreSQL Row-Level Security enforces strict data isolation between tenants.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 text-gray-400 shrink-0">—</span>
          <span>Webhook signature verification (HMAC-SHA256) prevents tampering.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 text-gray-400 shrink-0">—</span>
          <span>Audit logs retained for 5 years; access permissions follow the principle of least privilege.</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- A6. About the operator -->
  <section class="py-20 bg-gray-50 border-t border-gray-100">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-5">
        About the operator
      </h2>
      <dl class="space-y-4 text-sm">
        <div class="flex flex-col sm:flex-row sm:gap-6">
          <dt class="font-medium text-gray-900 sm:w-36 shrink-0">Business name</dt>
          <dd class="text-gray-600">HIGH LIFE JPN</dd>
        </div>
        <div class="flex flex-col sm:flex-row sm:gap-6">
          <dt class="font-medium text-gray-900 sm:w-36 shrink-0">Representative</dt>
          <dd class="text-gray-600">Shingo Tanizawa</dd>
        </div>
        <div class="flex flex-col sm:flex-row sm:gap-6">
          <dt class="font-medium text-gray-900 sm:w-36 shrink-0">Address</dt>
          <dd class="text-gray-600">2F, Nishi-Shinjuku Mizuma Building, 3-3-13 Nishi-Shinjuku, Shinjuku-ku, Tokyo 160-0023, Japan</dd>
        </div>
        <div class="flex flex-col sm:flex-row sm:gap-6">
          <dt class="font-medium text-gray-900 sm:w-36 shrink-0">Contact</dt>
          <dd class="text-gray-600">
            <a href="mailto:support@salesanchor.jp" class="text-gray-900 hover:text-gray-600 no-underline">
              support@salesanchor.jp
            </a>
          </dd>
        </div>
        <div class="flex flex-col sm:flex-row sm:gap-6">
          <dt class="font-medium text-gray-900 sm:w-36 shrink-0">Support hours</dt>
          <dd class="text-gray-600">Monday – Friday, 10:00 – 18:00 JST (excluding national holidays)</dd>
        </div>
        <div class="flex flex-col sm:flex-row sm:gap-6">
          <dt class="font-medium text-gray-900 sm:w-36 shrink-0">Website</dt>
          <dd class="text-gray-600">
            <a href="https://salesanchor.jp" class="text-gray-900 hover:text-gray-600 no-underline">
              https://salesanchor.jp
            </a>
          </dd>
        </div>
      </dl>
    </div>
  </section>
</BaseLayout>
