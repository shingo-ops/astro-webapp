---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="The CRM built for cross-border TCG exporters"
  description="Stop juggling Excel tabs, DMs, and invoices. Sales Anchor gives TCG exporters one place to unify every channel, manage catalog, and automate invoicing — so a small team can handle hundreds of B2B deals without losing track."
>
  <!-- S1. Hero (split) -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

        <!-- Left: headline + sublines -->
        <div class="pt-4">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
            The CRM built for cross-border TCG exporters.
          </h1>
          <ul class="mt-6 space-y-3 list-none p-0">
            <li class="text-lg text-gray-600 leading-relaxed">Unify every channel, every customer, every deal — in one place.</li>
            <li class="text-lg text-gray-600 leading-relaxed">Control your records and workflows with structure.</li>
            <li class="text-lg text-gray-600 leading-relaxed">Analyze what's working and find your next move.</li>
          </ul>
        </div>

        <!-- Right: form-card -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8">
          <h2 class="text-xl font-semibold text-gray-900 mb-6">Request a brochure</h2>
          <form
            action="mailto:support@salesanchor.jp?subject=Brochure%20request"
            method="post"
            enctype="text/plain"
          >
            <div class="space-y-4">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
                  Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="Name"
                  required
                  class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-gray-700 mb-1">
                  Company name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="company"
                  name="Company"
                  required
                  class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                  Email <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="Email"
                  required
                  class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
                  Phone
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="Phone"
                  class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                />
              </div>
              <div>
                <label for="size" class="block text-sm font-medium text-gray-700 mb-1">
                  Company size
                </label>
                <select
                  id="size"
                  name="Company size"
                  class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 bg-white"
                >
                  <option value="">Select…</option>
                  <option value="1-10">1–10</option>
                  <option value="11-50">11–50</option>
                  <option value="51-200">51–200</option>
                  <option value="201-500">201–500</option>
                  <option value="501+">501+</option>
                </select>
              </div>
              <button
                type="submit"
                class="w-full py-3 px-4 bg-brand-500 hover:bg-brand-600 text-white font-medium rounded-md transition-colors text-sm mt-2"
              >
                Send request →
              </button>
            </div>
          </form>
          <p class="mt-3 text-xs text-gray-400 text-center">Our team will follow up shortly.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- S2. Feature tabs -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">

      <!-- Tab buttons -->
      <div class="flex border-b border-gray-200 overflow-x-auto" role="tablist">
        <button
          role="tab"
          aria-selected="true"
          aria-controls="tab-panel-sales"
          data-tab="sales"
          class="tab-btn px-5 py-3 text-sm font-medium text-brand-600 border-b-2 border-brand-500 whitespace-nowrap -mb-px focus:outline-none"
        >
          Sales
        </button>
        <button
          role="tab"
          aria-selected="false"
          aria-controls="tab-panel-marketing"
          data-tab="marketing"
          class="tab-btn px-5 py-3 text-sm font-medium text-gray-500 hover:text-gray-900 border-b-2 border-transparent whitespace-nowrap -mb-px focus:outline-none"
        >
          Marketing
        </button>
        <button
          role="tab"
          aria-selected="false"
          aria-controls="tab-panel-customer"
          data-tab="customer"
          class="tab-btn px-5 py-3 text-sm font-medium text-gray-500 hover:text-gray-900 border-b-2 border-transparent whitespace-nowrap -mb-px focus:outline-none"
        >
          Customer
        </button>
        <button
          role="tab"
          aria-selected="false"
          aria-controls="tab-panel-data"
          data-tab="data"
          class="tab-btn px-5 py-3 text-sm font-medium text-gray-500 hover:text-gray-900 border-b-2 border-transparent whitespace-nowrap -mb-px focus:outline-none"
        >
          Data
        </button>
        <button
          role="tab"
          aria-selected="false"
          aria-controls="tab-panel-ai"
          data-tab="ai"
          class="tab-btn px-5 py-3 text-sm font-medium text-gray-500 hover:text-gray-900 border-b-2 border-transparent whitespace-nowrap -mb-px focus:outline-none"
        >
          AI
        </button>
      </div>

      <!-- Tab panels -->
      <div class="mt-10">

        <!-- Sales -->
        <div
          id="tab-panel-sales"
          role="tabpanel"
          class="tab-panel grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
        >
          <div>
            <h3 class="text-2xl font-semibold text-gray-900">Sales enablement</h3>
            <p class="mt-3 text-gray-500 leading-relaxed">
              Close more deals with AI-powered prioritization and unified communication tools built for B2B TCG trade.
            </p>
            <ul class="mt-6 grid grid-cols-2 gap-3 list-none p-0">
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Pipeline management</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Customer record</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Email + call unification</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>AI priority scoring</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Sales report</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Team goal tracking</li>
            </ul>
          </div>
          <div class="bg-brand-50 rounded-xl h-64 flex items-center justify-center border border-brand-100">
            <div class="text-center">
              <div class="text-5xl mb-3">📊</div>
              <p class="text-sm text-brand-400 font-medium">Product screenshot — coming soon</p>
            </div>
          </div>
        </div>

        <!-- Marketing -->
        <div
          id="tab-panel-marketing"
          role="tabpanel"
          class="tab-panel grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
          style="display:none"
        >
          <div>
            <h3 class="text-2xl font-semibold text-gray-900">Marketing automation</h3>
            <p class="mt-3 text-gray-500 leading-relaxed">
              Capture leads, nurture them with targeted campaigns, and hand off qualified prospects to sales seamlessly.
            </p>
            <ul class="mt-6 grid grid-cols-2 gap-3 list-none p-0">
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Lead capture form</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Email campaigns</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Social integration</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>AI content</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Segmentation</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Marketing report</li>
            </ul>
          </div>
          <div class="bg-brand-50 rounded-xl h-64 flex items-center justify-center border border-brand-100">
            <div class="text-center">
              <div class="text-5xl mb-3">📧</div>
              <p class="text-sm text-brand-400 font-medium">Product screenshot — coming soon</p>
            </div>
          </div>
        </div>

        <!-- Customer -->
        <div
          id="tab-panel-customer"
          role="tabpanel"
          class="tab-panel grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
          style="display:none"
        >
          <div>
            <h3 class="text-2xl font-semibold text-gray-900">Customer experience</h3>
            <p class="mt-3 text-gray-500 leading-relaxed">
              Deliver consistent, high-quality support that builds long-term loyalty and turns customers into advocates.
            </p>
            <ul class="mt-6 grid grid-cols-2 gap-3 list-none p-0">
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Support ticketing</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Chatbot</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>NPS</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Interaction history</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>SLA</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Satisfaction survey</li>
            </ul>
          </div>
          <div class="bg-brand-50 rounded-xl h-64 flex items-center justify-center border border-brand-100">
            <div class="text-center">
              <div class="text-5xl mb-3">💬</div>
              <p class="text-sm text-brand-400 font-medium">Product screenshot — coming soon</p>
            </div>
          </div>
        </div>

        <!-- Data -->
        <div
          id="tab-panel-data"
          role="tabpanel"
          class="tab-panel grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
          style="display:none"
        >
          <div>
            <h3 class="text-2xl font-semibold text-gray-900">Unified data</h3>
            <p class="mt-3 text-gray-500 leading-relaxed">
              Consolidate every customer record into one structured database that your entire team can trust and act on.
            </p>
            <ul class="mt-6 grid grid-cols-2 gap-3 list-none p-0">
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>CRM database</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Custom properties</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>API integration</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Data hygiene</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Segmentation</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Export-import</li>
            </ul>
          </div>
          <div class="bg-brand-50 rounded-xl h-64 flex items-center justify-center border border-brand-100">
            <div class="text-center">
              <div class="text-5xl mb-3">🗄️</div>
              <p class="text-sm text-brand-400 font-medium">Product screenshot — coming soon</p>
            </div>
          </div>
        </div>

        <!-- AI -->
        <div
          id="tab-panel-ai"
          role="tabpanel"
          class="tab-panel grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
          style="display:none"
        >
          <div>
            <h3 class="text-2xl font-semibold text-gray-900">AI automation</h3>
            <p class="mt-3 text-gray-500 leading-relaxed">
              Let AI handle repetitive tasks so your team can focus on high-value conversations and relationship building.
            </p>
            <ul class="mt-6 grid grid-cols-2 gap-3 list-none p-0">
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Conversation summary</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Auto follow-up</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Next best action</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Lead scoring</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Sales forecast</li>
              <li class="flex items-center gap-2 text-sm text-gray-700"><span class="w-1.5 h-1.5 rounded-full bg-brand-500 shrink-0"></span>Workflow automation</li>
            </ul>
          </div>
          <div class="bg-brand-50 rounded-xl h-64 flex items-center justify-center border border-brand-100">
            <div class="text-center">
              <div class="text-5xl mb-3">🤖</div>
              <p class="text-sm text-brand-400 font-medium">Product screenshot — coming soon</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;

        tabs.forEach((t) => {
          const isActive = t.dataset.tab === target;
          t.setAttribute('aria-selected', String(isActive));
          if (isActive) {
            t.classList.add('text-brand-600', 'border-brand-500');
            t.classList.remove('text-gray-500', 'border-transparent');
          } else {
            t.classList.remove('text-brand-600', 'border-brand-500');
            t.classList.add('text-gray-500', 'border-transparent');
          }
        });

        panels.forEach((panel) => {
          const isActive = panel.id === `tab-panel-${target}`;
          panel.style.display = isActive ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
