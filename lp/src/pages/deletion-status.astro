---
import LegalLayout from '../layouts/LegalLayout.astro';

const apiBase = 'https://api.salesanchor.jp/api/v1/meta';
---

<LegalLayout
  title="Deletion Status"
  description="Check the processing status of your Sales Anchor data deletion request."
  subtitle="Enter your confirmation code to check deletion progress."
  noindex={true}
>
  <article>
    <h1>Deletion Status</h1>

    <p class="text-base text-gray-700">
      Visit this page with a confirmation code (<code>DEL-YYYYMMDD-xxxx</code>) in the URL to check the status of your deletion request.
    </p>

    <div id="status-card" class="not-prose mt-8 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <p class="text-gray-500" id="status-loading">Loading…</p>
    </div>

    <h2 class="mt-12">Contact</h2>
    <p>
      For questions, please contact <a href="mailto:support@salesanchor.jp">support@salesanchor.jp</a>.
    </p>
  </article>

  <script is:inline define:vars={{ apiBase }}>
    (function () {
      const params = new URLSearchParams(window.location.search);
      const code = params.get('code') || '';
      const card = document.getElementById('status-card');

      function render(html) {
        card.innerHTML = html;
      }

      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      const codeRe = /^DEL-\d{8}-[a-f0-9]{8}$/;
      if (!code || !codeRe.test(code)) {
        render(
          '<p class="text-red-600">' +
            'Invalid confirmation code.' +
            '</p>' +
            '<p class="mt-2 text-sm text-gray-600">' +
            'Please access this page with <code>?code=DEL-YYYYMMDD-xxxx</code> in the URL.' +
            '</p>'
        );
        return;
      }

      const url = apiBase + '/deletion-status?code=' + encodeURIComponent(code);

      fetch(url, { headers: { Accept: 'application/json' } })
        .then(function (res) {
          if (res.status === 404) {
            return res.json().then(function () {
              render(
                '<h3 class="font-semibold text-red-600">Confirmation code not found</h3>' +
                  '<p class="mt-2 text-sm text-gray-600">' +
                  'Code: <code>' +
                  escapeHtml(code) +
                  '</code></p>' +
                  '<p class="mt-2 text-sm text-gray-600">' +
                  'Please verify the code is correct and contact us if the issue persists.' +
                  '</p>'
              );
            });
          }
          if (!res.ok) {
            return res.json().then(function () {
              render(
                '<h3 class="font-semibold text-red-600">An error occurred</h3>' +
                  '<p class="mt-2 text-sm text-gray-600">' +
                  'HTTP ' +
                  res.status +
                  '</p>' +
                  '<p class="mt-2 text-sm text-gray-600">Please try again later.</p>'
              );
            });
          }
          return res.json().then(function (data) {
            const statusLabels = {
              received: 'Received',
              verifying: 'Verifying',
              processing: 'Processing',
              completed: 'Completed',
              failed: 'Failed',
              rejected: 'Rejected',
            };
            const statusLabel = statusLabels[data.status] || data.status;

            const fmt = function (iso) {
              if (!iso) return '—';
              try {
                const d = new Date(iso);
                return d.toLocaleString('en-US', { timeZone: 'Asia/Tokyo' });
              } catch (e) {
                return iso;
              }
            };

            render(
              '<dl class="space-y-3 text-sm">' +
                '<div class="flex flex-col sm:flex-row sm:gap-4">' +
                '<dt class="font-semibold text-gray-900 sm:w-40">Confirmation code</dt>' +
                '<dd><code>' +
                escapeHtml(data.confirmation_code) +
                '</code></dd>' +
                '</div>' +
                '<div class="flex flex-col sm:flex-row sm:gap-4">' +
                '<dt class="font-semibold text-gray-900 sm:w-40">Status</dt>' +
                '<dd class="font-semibold ' +
                (data.status === 'completed'
                  ? 'text-green-600'
                  : data.status === 'failed' || data.status === 'rejected'
                  ? 'text-red-600'
                  : 'text-blue-600') +
                '">' +
                escapeHtml(statusLabel) +
                '</dd>' +
                '</div>' +
                '<div class="flex flex-col sm:flex-row sm:gap-4">' +
                '<dt class="font-semibold text-gray-900 sm:w-40">Requested at</dt>' +
                '<dd>' +
                escapeHtml(fmt(data.requested_at)) +
                '</dd>' +
                '</div>' +
                '<div class="flex flex-col sm:flex-row sm:gap-4">' +
                '<dt class="font-semibold text-gray-900 sm:w-40">Processing started</dt>' +
                '<dd>' +
                escapeHtml(fmt(data.started_at)) +
                '</dd>' +
                '</div>' +
                '<div class="flex flex-col sm:flex-row sm:gap-4">' +
                '<dt class="font-semibold text-gray-900 sm:w-40">Completed at</dt>' +
                '<dd>' +
                escapeHtml(fmt(data.completed_at)) +
                '</dd>' +
                '</div>' +
                '</dl>'
            );
          });
        })
        .catch(function (err) {
          render(
            '<h3 class="font-semibold text-red-600">Network Error</h3>' +
              '<p class="mt-2 text-sm text-gray-600">' +
              escapeHtml(err.message || 'Unknown error') +
              '</p>'
          );
        });
    })();
  </script>
</LegalLayout>
