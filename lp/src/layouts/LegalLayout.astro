---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  subtitle?: string;
  canonical?: string;
  noindex?: boolean;
}

const { title, description, subtitle, canonical, noindex = false } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} noindex={noindex}>
  <!-- ── Hero Banner (brand-navy, matches CTA section on LP) ── -->
  <div class="bg-brand-navy py-14 md:py-20">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Breadcrumb -->
      <p class="text-xs font-semibold uppercase tracking-widest mb-5" style="color:rgba(96,165,250,0.7)">
        <a href="/" class="transition-colors hover:text-blue-400" style="color:rgba(96,165,250,0.7);text-decoration:none;">
          Sales Anchor
        </a>
        <span class="mx-2" style="color:rgba(100,116,139,0.6)">›</span>
        <span style="color:rgba(148,163,184,0.9)">{title}</span>
      </p>

      <!-- Title -->
      <h1 class="font-serif font-normal text-white leading-tight text-3xl md:text-4xl lg:text-[2.75rem]">
        {title}
      </h1>

      {subtitle && (
        <p class="mt-4 text-slate-300 text-base md:text-lg max-w-2xl leading-relaxed">
          {subtitle}
        </p>
      )}
    </div>
  </div>

  <!-- ── Content Area ── -->
  <div class="bg-white py-14 md:py-20">
    <div class="max-w-3xl mx-auto px-4">
      <article class="sa-legal">
        <slot />
      </article>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* ── Hide in-page H1 (displayed in the hero banner instead) ── */
  .sa-legal > h1:first-child {
    display: none;
  }

  /* ── Base ── */
  .sa-legal {
    color: #475569; /* slate-600 */
    font-size: 0.9375rem;
    line-height: 1.75;
  }

  /* ── Headings ── */
  .sa-legal h2 {
    font-family: "DM Serif Display", Georgia, serif;
    font-weight: 400;
    font-size: 1.375rem;
    color: #0f172a; /* slate-900 */
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #1877f2; /* brand-500 */
  }

  .sa-legal h3 {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.9375rem;
    color: #1e293b; /* slate-800 */
    margin-top: 2rem;
    margin-bottom: 0.625rem;
  }

  .sa-legal h4 {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748b; /* slate-500 */
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  /* ── Body text ── */
  .sa-legal p {
    margin-bottom: 1rem;
    line-height: 1.75;
  }

  /* ── Links ── */
  .sa-legal a {
    color: #166fe5; /* brand-600 */
    text-underline-offset: 3px;
    transition: color 0.15s;
  }
  .sa-legal a:hover {
    color: #1463cc; /* brand-700 */
  }

  /* ── Lists ── */
  .sa-legal ul,
  .sa-legal ol {
    margin-bottom: 1rem;
    padding-left: 0;
    list-style: none;
  }

  .sa-legal ul li,
  .sa-legal ol li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.375rem;
    font-size: 0.9375rem;
    color: #475569;
    line-height: 1.65;
  }

  .sa-legal ul li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: #1877f2; /* brand-500 */
    font-weight: 700;
    line-height: 1.65;
  }

  .sa-legal ol {
    counter-reset: sa-ol;
  }
  .sa-legal ol li::before {
    counter-increment: sa-ol;
    content: counter(sa-ol) ".";
    position: absolute;
    left: 0;
    color: #1877f2;
    font-weight: 600;
    font-size: 0.8125rem;
    line-height: 1.8;
  }

  /* ── Strong / em ── */
  .sa-legal strong {
    font-weight: 600;
    color: #1e293b;
  }

  .sa-legal em {
    font-style: normal;
    color: #64748b;
    font-size: 0.875rem;
  }

  /* ── Code ── */
  .sa-legal code {
    background-color: #eff6ff; /* blue-50 */
    color: #1d4ed8;            /* blue-700 */
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
    font-size: 0.8125rem;
  }

  /* ── HR ── */
  .sa-legal hr {
    border: none;
    border-top: 1px solid #f1f5f9; /* slate-100 */
    margin: 3rem 0;
  }

  /* ── Tables ── */
  .sa-legal table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.07), 0 0 0 1px rgba(0, 0, 0, 0.04);
  }

  .sa-legal thead tr {
    background-color: #0a1628; /* brand-navy */
  }

  .sa-legal thead th {
    color: #cbd5e1; /* slate-300 */
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.75rem 1rem;
    text-align: left;
  }

  .sa-legal tbody tr {
    border-bottom: 1px solid #f1f5f9;
  }

  .sa-legal tbody tr:last-child {
    border-bottom: none;
  }

  .sa-legal tbody tr:nth-child(even) {
    background-color: #f8fafc; /* slate-50 */
  }

  .sa-legal tbody td {
    padding: 0.75rem 1rem;
    color: #475569;
    vertical-align: top;
    line-height: 1.6;
  }

  /* ── Meta info block (Version/Date line) ── */
  .sa-legal p.meta-info {
    background: #f8fafc;
    border-left: 3px solid #1877f2;
    padding: 0.875rem 1rem;
    border-radius: 0 0.5rem 0.5rem 0;
    font-size: 0.8125rem;
    color: #64748b;
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  /* ── Status card (deletion-status page) ── */
  .sa-legal #status-card {
    border-radius: 1rem;
    border: 1.5px solid #e2e8f0;
    background: #fff;
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(24, 119, 242, 0.06);
    margin-top: 1.5rem;
  }
</style>
