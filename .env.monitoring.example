# ===================================
# Sales Anchor 監視スタック用 環境変数テンプレート
# ===================================
# このファイルをコピーして /opt/salesanchor-monitoring/.env を作成してください:
#   cp .env.monitoring.example .env
# .env は Git で管理しません。

# --- Grafana ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=（強いパスワードを設定）
GF_SERVER_ROOT_URL=https://app.salesanchor.jp/grafana/
DISCORD_WEBHOOK_URL=

# --- Uptime Kuma ---
UPTIME_KUMA_API_KEY=

# --- GitHub Actions Exporter ---
# GitHub App の App ID
GHA_APP_ID=
# 秘密鍵 PEM の絶対パス（VPS 上）
GHA_APP_KEY_PATH=/opt/salesanchor-monitoring/secrets/gha-exporter-key.pem

# --- 参考値（必要に応じて変更） ---
APP_VPS_IP=49.212.137.46
MGMT_PUBLIC_IP=49.212.160.98
