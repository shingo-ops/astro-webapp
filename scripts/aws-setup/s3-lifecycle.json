{
    "Rules": [
        {
            "ID": "DeleteOldBackupsAfter90Days",
            "Status": "Enabled",
            "Filter": {
                "Prefix": "postgres-backups/"
            },
            "Expiration": {
                "Days": 90
            }
        },
        {
            "_comment": "monthly-archives/ は永久保存のため削除ルールを意図的に設定しない。Glacierストレージクラスで保持。",
            "ID": "MonthlyArchivesNoExpiry",
            "Status": "Disabled",
            "Filter": {
                "Prefix": "monthly-archives/"
            },
            "Expiration": {
                "Days": 36500
            }
        },
        {
            "ID": "DeleteIncompleteMultipartUploads",
            "Status": "Enabled",
            "Filter": {},
            "AbortIncompleteMultipartUpload": {
                "DaysAfterInitiation": 7
            }
        }
    ]
}
