{
    "Rules": [
        {
            "ID": "DeleteOldBackupsAfter90Days",
            "Status": "Enabled",
            "Filter": {
                "Prefix": "postgres-backups/"
            },
            "Expiration": {
                "Days": 90
            }
        },
        {
            "ID": "DeleteIncompleteMultipartUploads",
            "Status": "Enabled",
            "Filter": {},
            "AbortIncompleteMultipartUpload": {
                "DaysAfterInitiation": 7
            }
        }
    ]
}
