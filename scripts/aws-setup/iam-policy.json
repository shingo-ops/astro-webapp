{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "JarvisBackupS3Access",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:DeleteObject",
                "s3:ListBucket",
                "s3:GetObjectAttributes",
                "s3:RestoreObject"
            ],
            "Resource": [
                "arn:aws:s3:::salesanchor-backups",
                "arn:aws:s3:::salesanchor-backups/*"
            ]
        }
    ]
}
